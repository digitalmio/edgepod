{
  "name": "@edgepod/server",
  "version": "0.0.6",
  "description": "Server component of Edgepod - Handles API requests, database interactions, and server-side logic",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "Maciej Ziehlke <mac@dmio.co>",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema.d.ts",
        "default": "./dist/schema.js"
      },
      "require": {
        "types": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsdown"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260423.1",
    "@logtape/logtape": "^2.0.5",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "pnpm@10.33.2"
}
